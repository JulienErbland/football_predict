# ── Environment ────────────────────────────────────────────────────────────
.env
.env.local

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/

# ── Data ───────────────────────────────────────────────────────────────────
# Raw / processed / features / models live locally only.
backend/data/raw/
backend/data/processed/
backend/data/features/
backend/data/models/

# Local backups kept for rollback safety, not source-of-truth.
backend/data/_backup_*/
*.backup
predictions_before_*.json
the-odds-api.json

# Model binaries (any path)
*.pkl
*.joblib

# But include curated prediction outputs that ship to the frontend.
!backend/data/output/*.json
!frontend/public/data/*.json

# Local evaluation/prediction artifacts (canonical predictions live in
# frontend/public/data/). These are regenerated by every training / predict
# run and have no business at HEAD.
backend/data/output/eval_*.json
backend/data/output/predictions.json
backend/data/output/predictions_test.json

# ── Node / Next.js ─────────────────────────────────────────────────────────
node_modules/
.npm
frontend/.next/
frontend/out/
frontend/.vercel/

# ── Smoke-test sandboxes (tools/pipeline_test.py default --sandbox-dir) ────
tmp_smoke/
tmp_ci_smoke/

# ── IDE / editors ──────────────────────────────────────────────────────────
.claude/
.vscode/
.idea/
*.swp

# ── Misc ───────────────────────────────────────────────────────────────────
.DS_Store
*.log
.vercel
